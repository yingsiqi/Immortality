# Immortality AuthService — Dockerfile
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY . .
RUN dotnet restore src/Immortality.AuthService/Immortality.AuthService.csproj
RUN dotnet publish src/Immortality.AuthService/Immortality.AuthService.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 5001
ENTRYPOINT ["dotnet", "Immortality.AuthService.dll"]

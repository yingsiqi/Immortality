# Immortality Gateway — Dockerfile
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY . .
RUN dotnet restore src/Immortality.Gateway/Immortality.Gateway.csproj
RUN dotnet publish src/Immortality.Gateway/Immortality.Gateway.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 3001
ENTRYPOINT ["dotnet", "Immortality.Gateway.dll"]

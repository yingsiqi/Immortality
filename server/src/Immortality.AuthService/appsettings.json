{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=immortality;Username=postgres;Password=postgres",
    "Redis": "localhost:6379",
    "EventStore": "esdb://localhost:2113?tls=false",
    "MinIO": "http://localhost:9000"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "Immortality.AuthService",
    "Audience": "Immortality.Client",
    "AccessTokenExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}

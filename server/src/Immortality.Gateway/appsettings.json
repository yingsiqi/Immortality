{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "Immortality.AuthService",
    "Audience": "Immortality.Client"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "game-route": {
        "ClusterId": "game-cluster",
        "Match": { "Path": "/api/player/{**catch-all}" }
      },
      "cultivation-route": {
        "ClusterId": "game-cluster",
        "Match": { "Path": "/api/cultivation/{**catch-all}" }
      },
      "realtime-route": {
        "ClusterId": "realtime-cluster",
        "Match": { "Path": "/realtime/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5001" }
        }
      },
      "game-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5002" }
        }
      },
      "realtime-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5003" }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
